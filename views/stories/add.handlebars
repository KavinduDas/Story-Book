<h1>Add</h1>
<div class="row">
    <form action="/stories" method = "post" class="col s12">
    <div class="row">
        <div class="input-field">
            <input type="text" name = "title">
            <label for="title">Title</label>
        </div>
    </div>
       <div class="row">
        <div class="input-field">
            <select name="status" >
                <option value="public" selected>Public</option>
                <option value="private">Private</option>
                <option value="unpublished">Unpublsihed</option>
            </select>
            <label for="status">Status</label>
        </div>
    </div>
    <div class="row">
        <p>
            <label>
                <input type="checkbox" name="allowComments" class="filled-in" 
                    id="allowComments" checked="checked">
                <span>Allow Comments</span>
            </label>
        </p>
    </div>
         <div class="row">
        <div class="input-field">
            <h5>Tell us</h5>
            <textarea name="body" class="materialize-textarea"></textarea>

        </div>
    </div>
    <input type="submit" value="Save" class="btn">
    </form>
</div>

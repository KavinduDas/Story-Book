<h1>Stories</h1>
<div class="row">
    {{#each stories}}
    <div class="col s12 m4">
        <div class="card">
            <div class="card-action">
                {{#if user}}
                    {{{editIcon user.id ../user.id id}}}
                {{/if}}
            </div>
            <div class="card-content center-align">
                <h3 class="heading-text">{{{title}}}</h2>
                <p class="story-text">{{truncate (stripTags body) 150}}</p>
                <br>
                  <div class="chip">
                    <img src="{{user.image}}" referrerpolicy="no-referrer">
                    <a href="/stories/user/{{user._id}}">
                    {{user.firstname}}</a>
                </div>
            </div>  
            <div class="card-action center-align">
            <a href="/stories/show/{{_id}}" class="btn grey">Read more</a>
            </div>
        </div>
    </div>
    {{else}}
    <p>No stories</p>


    {{/each}}
</div>
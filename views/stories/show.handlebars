<div class="row">
    <div class="col s12 m9">
        <h3>{{story.title}}</h3>
        <div class="card-story">
            <div class="card-content">
                <h5>{{formatdate story.Date 'MMMM Do YYYY'}}</h5>
                {{{story.body}}}
            </div>
        </div>
        {{#if story.allowComments}}
            <div class="card">
                <div class="card-content">
                    <span class="card-title">Comments</span>
                    {{#if user}}
                    <form action="/stories/comment/{{story._id}}" method="post">
                        <div class="input-field">
                           <textarea name="commentbody" class="materialize-textarea"></textarea>
                            <label>Add comment</label>
                        </div>
                        <input type="submit" value="submit" class="btn">
                    </form>
                    {{else}}
                        <p><a href="/auth/google">Please sign in to leave a comment</a></p>
                    {{/if}}
                </div>
            </div>
            {{#each story.comments}}
                <div class="card">
                    <div class="card-contenht">
                        <h5>{{commentBody}}</h5>
                    <div class="chip">
                    <img src="{{commentuser.image}}" referrerpolicy="no-referrer">
                    {{commentuser.firstname}}
                    <br>
                    <small>{{formatdate commentDate 'MMMM Do YYYY'}}</small>
                </div>
                    </div>
                </div>
            {{/each}}
        {{/if}}
    </div>
    <div class="col s12 m3">
        <div class="card center-align">
            <div class="card-content">
                <span class="card-title">{{story.user.firstname}} {{story.user.lastname}}</span>
                <img src="{{story.user.image}}" class="circle responsive">
            </div>
            <a href="/stories/user/{{story.user._id}}">More from user</a>
        </div>
    </div>
</div>
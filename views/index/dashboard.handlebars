<h1>Welcome {{user.firstname}}</h1>
{{#if stories}}
<table>
    <thead>
        <tr>
            <th>Title</th>
            <th>Date</th>
            <th>Status</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        {{#each stories}}
            <tr>
                <td><a href="/stories/show/{{_id}}">{{title}}</a></td>
                <td>{{formatdate stories.Date 'MMMM Do YYYY'}}</td>
                <td><span class="txt-dashboard">{{status}}</span></td>
                <td>
                    <a href="/stories/edit/{{_id}}" class="btn left-align"><i class="fas fa-pen"></i>Edit</a>
                    <form  action="/stories/{{_id}}?_method=DELETE" method="post" id="delete-button">
                    <input type="hidden" name="_method" value="DELETE">
                        <button type="submit" class="btn red"><i class="fas fa-times"></i>Delete</button>
                    </form>
                </td>
            </tr>
        {{/each}}
    </tbody>
</table>

{{else}}
<p>You have no stories</p>
{{/if}}